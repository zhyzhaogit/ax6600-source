 static int ssdk_dsa_event_link_change(struct net_device *dev, bool link)
 {
 	struct dsa_port *dp = NULL;
@@ -1315,6 +1322,100 @@ static int ssdk_dsa_event_nb(struct noti
 static struct notifier_block ssdk_dsa_notifier_nb = {
 	.notifier_call = ssdk_dsa_event_nb,
 };
+#elif IS_ENABLED(CONFIG_NET_DSA) && (LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0))
+static int ssdk_dsa_phylink_notifier_refs;
+
+static int ssdk_dsa_phylink_event_nb(struct notifier_block *unused,
+		unsigned long event, void *ptr)
+{
+	ssdk_port_status *status = ptr;
+	struct net_device *dev;
+	int notified = NOTIFY_DONE;
+
+	(void)unused;
+	(void)event;
+
+	if (!status)
+		return NOTIFY_DONE;
+
+	rtnl_lock();
+
+	for_each_netdev(&init_net, dev) {
+		ssdk_netdev_switch_t *netdev_switch = NULL;
+		struct qca_phy_priv* priv = NULL;
+		struct net_device *conduit = NULL;
+		struct dsa_port *dp = NULL;
+
+		if (!dsa_user_dev_check(dev))
+			continue;
+
+		dp = dsa_port_from_netdev(dev);
+		if (!dp || !dp->ds || !dp->cpu_dp || !dp->pl)
+			continue;
+
+		if (dp->index != status->port_id)
+			continue;
+
+		conduit = dsa_port_to_conduit(dp);
+		if (!conduit)
+			continue;
+
+		netdev_switch = ssdk_dts_netdev_switch_find_by_netdev(conduit);
+		if (!netdev_switch)
+			continue;
+
+		priv = ssdk_phy_priv_data_get(netdev_switch->switch_dev_id);
+		if (!priv)
+			continue;
+
+		if (priv->version != QCA_VER_MHT &&
+			priv->version != QCA_VER_AR8337 &&
+			priv->version != QCA_VER_AR8327)
+			continue;
+
+		dsa_port_phylink_mac_change(dp->ds, dp->index,
+				status->port_link);
+		notified = NOTIFY_OK;
+		break;
+	}
+
+	rtnl_unlock();
+
+	return notified;
+}
+
+static struct notifier_block ssdk_dsa_phylink_notifier_nb = {
+	.notifier_call = ssdk_dsa_phylink_event_nb,
+};
+
+static void ssdk_dsa_phylink_notifier_register(void)
+{
+	int ret;
+
+	if (ssdk_dsa_phylink_notifier_refs) {
+		ssdk_dsa_phylink_notifier_refs++;
+		return;
+	}
+
+	ret = ssdk_port_link_notify_register(&ssdk_dsa_phylink_notifier_nb);
+	if (ret) {
+		SSDK_ERROR("register ssdk dsa phylink notifier failed: %d\n", ret);
+		return;
+	}
+
+	ssdk_dsa_phylink_notifier_refs = 1;
+}
+
+static void ssdk_dsa_phylink_notifier_unregister(void)
+{
+	if (!ssdk_dsa_phylink_notifier_refs)
+		return;
+
+	if (--ssdk_dsa_phylink_notifier_refs)
+		return;
+
+	ssdk_port_link_notify_unregister(&ssdk_dsa_phylink_notifier_nb);
+}
 #endif
 
